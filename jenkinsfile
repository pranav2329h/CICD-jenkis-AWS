node {

    def appDir = '/var/www/nextjs-app'

    stage('Clean Workspace') {
        deleteDir()
    }

    stage('Clone Repo') {
        git(
            branch: 'main',
            url: 'https://github.com/pranav2329h/CICD-jenkis-AWS.git'
        )
    }

    stage('Deploy to EC2') {

        sh """
            sudo mkdir -p ${appDir}
            sudo chown -R jenkins:jenkins ${appDir}

            rsync -av --delete \
            --exclude='.git' \
            --exclude='node_modules' \
            ./ ${appDir}

            cd ${appDir}

            npm install
            npm run build

            pm2 delete nextjs-app || true
            pm2 start npm --name nextjs-app -- start
            pm2 save
        """
    }
}